# KazAI — Environment Variables
# Бұл файлды .env деп атаңыз және GitHub-қа жүктемеңіз!

# OpenRouter API Key
# https://openrouter.ai/keys беттен алыңыз
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Flask секреттік кілттер (кез-келген ұзын random string)
SECRET_KEY=kazai-super-secret-key-change-this-in-production
JWT_SECRET=kazai-jwt-secret-change-this-too

# Деплой ортасы
FLASK_ENV=development
FLASK_DEBUG=1

# Render.com деплойда осыларды орнатасыз (Environment Variables бөлімінде)
